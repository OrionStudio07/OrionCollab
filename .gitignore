# ============================================================================
# OrionCollab — .gitignore
# Unreal Engine 5.8 · Industry Standard
# ============================================================================

# ---------------------------------------------------------------------------
# Unreal Engine — Build & Generated
# ---------------------------------------------------------------------------
Binaries/
Intermediate/
Saved/
DerivedDataCache/
Build/

# ---------------------------------------------------------------------------
# Visual Studio / Rider
# ---------------------------------------------------------------------------
.vs/
.idea/
.vscode/
*.user
*.suo
*.userosscache
*.sln.docstates
*.sln
*.slnx
*.VC.db
*.VC.opendb

# ---------------------------------------------------------------------------
# Unreal Engine — Generated Project Files
# ---------------------------------------------------------------------------
*.xcworkspace
*.xcodeproj

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
*.egg-info/
.eggs/

# ---------------------------------------------------------------------------
# OS Files
# ---------------------------------------------------------------------------
Thumbs.db
.DS_Store
Desktop.ini
*.tmp

# ---------------------------------------------------------------------------
# Logs & Debug Output
# ---------------------------------------------------------------------------
*.log
inspect_results.txt

# ---------------------------------------------------------------------------
# Obsidian (Vault metadata — not relevant on GitHub)
# ---------------------------------------------------------------------------
.obsidian/
Home.md

# ---------------------------------------------------------------------------
# Development Scratch Files
# ---------------------------------------------------------------------------
scratch/

# ---------------------------------------------------------------------------
# AI Agent Session Data (keep rules/skills, ignore ephemeral data)
# ---------------------------------------------------------------------------
.agents/brain/
.agents/.skill-lock.json
